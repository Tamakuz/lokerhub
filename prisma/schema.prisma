generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model JobPost {
  id             String   @id
  title          String
  company        String
  location       String
  salaryText     String?
  employmentType String
  category       String
  sourceName     String
  sourceUrl      String   @unique
  description    String
  postedAt       DateTime
  scrapedAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([title])
  @@index([location])
  @@index([category])
  @@index([sourceName])
}
